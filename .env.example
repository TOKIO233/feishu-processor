# feishu2md app credentials (required for /api/download and /api/process)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# WeChat image host
WECHAT_ENABLED=false
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_API_BASE_URL=https://api.weixin.qq.com/cgi-bin

# Aliyun OSS image host
ALIYUN_ENABLED=false
ALIYUN_REGION=oss-cn-hangzhou
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_BUCKET=
ALIYUN_ENDPOINT=
ALIYUN_CDN_DOMAIN=

# Upload tuning
UPLOAD_MAX_CONCURRENCY=5
UPLOAD_RETRY_COUNT=3
UPLOAD_TIMEOUT=30000
